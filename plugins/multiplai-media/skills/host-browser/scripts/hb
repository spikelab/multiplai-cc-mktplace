#!/usr/bin/env bash
# hb — human-paced wrapper around `ab` (agent-browser on the host).
#
# Drop-in for `ab`: any verb `ab` understands, `hb` forwards verbatim, so you
# can use `hb snapshot -i`, `hb get url`, etc. On top of that it adds a few
# verbs that defeat behavioural bot-detection (instant fills / zero think-time
# are the giveaways once webdriver=false removes the static tells):
#
#   hb think [MIN_MS] [MAX_MS]      sleep a randomized human pause (default 400-1400)
#   hb humantype <sel> <text>      clear, then type in jittered word-chunks
#   hb humanclick <sel>            hover, micro-pause, then click
#   hb fillform <sel> <text> ...   humantype across alternating sel/text pairs
#   hb waitfor url|vis <arg> [s]   poll until URL matches / element visible (timeout)
#   hb mail new                    open mail.tm, print the anonymous inbox address
#   hb mail code [s]               poll the mail.tm inbox, print the OTP code
#
# humantype/fillform are metachar-safe: text containing the shell metacharacters
# the host gateway forbids ( ; | & < > ` $ ( ) or newline ) is inserted via a
# base64 `eval -b` path (programmatic, not real keystrokes — see insert_via_eval).
#
# Everything else: `hb <args...>` == `ab <args...>`.
set -euo pipefail

ab() { command ab "$@"; }

# random int in [$1,$2]
rnd() { echo $(( $1 + RANDOM % ($2 - $1 + 1) )); }
# sleep a random number of milliseconds in [$1,$2]
napms() { local ms; ms="$(rnd "$1" "$2")"; sleep "$(awk "BEGIN{printf \"%.3f\", $ms/1000}")"; }

think() { napms "${1:-400}" "${2:-1400}"; }

# has_meta <text> — true if the text contains a character the host gateway's
# metachar pre-filter forbids in an argument ( ; | & < > ` $ ( ) or newline ).
# Such text cannot be sent as an `ab type`/`fill` argument (the whole command is
# DENIED), so humantype routes it through insert_via_eval instead.
has_meta() {
  local s="$1" stripped
  stripped="${s//[;|&<>\`\$()]/}"     # drop the gateway-forbidden metacharacters
  stripped="${stripped//[[:cntrl:]]/}" # and ALL control chars (newline, tab, CR, …)
  # Control chars beyond newline matter too: a literal tab/CR mid-argument
  # dies at the gateway (or worse, gets typed as a focus-moving keystroke),
  # so they must take the eval path like the metacharacters do.
  [ "$stripped" != "$s" ]
}

# insert_via_eval <text> — set the FOCUSED element's value when the text can't
# cross the arg boundary. Operates on document.activeElement (the caller must
# `ab focus <ref>` first — this is ref-agnostic, since agent-browser's @eN refs
# are NOT valid CSS selectors and can't be re-resolved from eval). base64 both
# the text AND the wrapping snippet so nothing forbidden reaches the gateway
# (base64 alphabet A-Za-z0-9+/= is all allowed), then `eval -b`. Uses the native
# value setter + input/change events so React/Vue controlled inputs pick it up;
# falls back to textContent for contenteditable. NOT real keystrokes — weaker
# vs. behavioral keystroke-cadence detectors; used only when has_meta forces it.
insert_via_eval() {
  local text="$1" tb64 js
  tb64="$(printf '%s' "$text" | base64 | tr -d '\n')"
  js="(()=>{const el=document.activeElement;\
if(!el||el===document.body)return 'no-focus';\
const v=decodeURIComponent(escape(atob('${tb64}')));\
if(el instanceof HTMLInputElement||el instanceof HTMLTextAreaElement){\
const p=el instanceof HTMLTextAreaElement?HTMLTextAreaElement.prototype:HTMLInputElement.prototype;\
Object.getOwnPropertyDescriptor(p,'value').set.call(el,v);}\
else if(el.isContentEditable){el.textContent=v;}\
else return 'not-editable:'+el.tagName;\
el.dispatchEvent(new Event('input',{bubbles:true}));\
el.dispatchEvent(new Event('change',{bubbles:true}));return 'ok';})()"
  ab eval -b "$(printf '%s' "$js" | base64 | tr -d '\n')"
}

# Type text the way a person does: focus, clear, then emit small chunks with
# inter-chunk jitter and the occasional longer "thinking" pause. agent-browser
# `type` already sends real per-char keydown/press/up events; chunking + sleeps
# add the human cadence on top. Text with gateway-forbidden metacharacters can't
# be sent as an arg, so it falls back to insert_via_eval (programmatic insert).
humantype() {
  local sel="$1"; shift
  local text="$*"
  if has_meta "$text"; then
    echo "hb: metachar text → programmatic insert (not real keystrokes)" >&2
    ab focus "$sel" >/dev/null 2>&1 || true
    napms 120 320
    local res
    res="$(insert_via_eval "$text")" || true
    res="${res%\"}"; res="${res#\"}"
    if [ "$res" != "ok" ]; then
      # insert_via_eval returns 'no-focus' / 'not-editable:<TAG>' / '' when the
      # focused element wasn't a writable field — surface it, don't fake success.
      echo "hb: programmatic insert not confirmed (got '${res:-<empty>}') — field may be unset; check focus/ref" >&2
      return 1
    fi
    return 0
  fi
  ab focus "$sel" >/dev/null 2>&1 || true
  napms 120 320
  ab fill "$sel" "" >/dev/null 2>&1 || true   # clear existing value
  napms 80 220
  local i=0 n=${#text} chunk len
  while [ $i -lt $n ]; do
    len="$(rnd 2 5)"
    chunk="${text:$i:$len}"
    ab type "$sel" "$chunk" >/dev/null
    i=$((i + len))
    # mostly fast keystroke gaps, occasionally a longer pause
    if [ "$(rnd 1 100)" -le 12 ]; then napms 280 720; else napms 45 160; fi
  done
}

humanclick() {
  local sel="$1"
  ab hover "$sel" >/dev/null 2>&1 || true
  napms 140 460
  ab click "$sel"
}

# fillform @e1 "user@x.com" @e2 "secret" ...
fillform() {
  while [ $# -ge 2 ]; do
    humantype "$1" "$2"
    shift 2
    think 350 1100
  done
}

# dismiss [maxRounds] — what a human does on landing: accept the cookie banner
# and close blocking pop-ups so the page is usable. A JS scanner (run via
# `ab eval`) finds the single best dismiss target — cookie-ACCEPT first
# (multilingual, defaults to "accept all" like a real user), then modal CLOSE
# scoped to dialogs/high-z overlays — tags it, and agent-browser does a real
# click on it. Loops to peel stacked overlays. Safe: weak labels (bare
# "accept"/"ok") only fire inside a cookie/consent context; close only inside a
# dialog/overlay — so it won't click "Accept booking" or a content "X".
dismiss() {
  local max="${1:-4}" i=0 acted=0 res label kind
  while [ "$i" -lt "$max" ]; do
    i=$((i+1))
    res="$(ab eval --stdin <<'JS'
(() => {
  const norm = s => (s||'').replace(/\s+/g,' ').trim().toLowerCase();
  const vis = el => { if(!el) return false; const r = el.getBoundingClientRect();
    if(r.width<2||r.height<2) return false; const st = getComputedStyle(el);
    return !(st.visibility==='hidden'||st.display==='none'||+st.opacity===0); };
  const ctxText = el => { let c=el; for(let d=0; d<8 && c.parentElement; d++) c=c.parentElement;
    return norm(c.innerText||''); };
  const inOverlay = el => { if(el.closest('[role=dialog],[aria-modal="true"]')) return true;
    let c=el; for(let d=0; d<9 && c; d++){ const st=getComputedStyle(c);
      if((st.position==='fixed'||st.position==='sticky') && (+st.zIndex>=100)) return true; c=c.parentElement; }
    return false; };
  const ACCEPT = ['accept all cookies','accept all','accept all & continue','accetta tutti','accetta tutto',
    'tout accepter','alle akzeptieren','aceptar todo','aceptar todas','accept cookies','allow all cookies',
    'allow all','i accept','accept & continue','agree and continue','consent to all'];
  const ACCEPT_WEAK = ['accept','agree','ok','okay','got it','ok, got it','consent','allow','i agree','continue'];
  const CLOSE = ['close','chiudi','dismiss','schließen','schliessen','cerrar','fermer','×','✕','✖','x','no thanks','not now','maybe later'];
  const cookieCtx = t => /(cookie|consent|privacy|gdpr|preferenz|tracking|esperienza d.uso|utilizziamo|we use)/.test(t);
  const sel = 'button,a[role=button],[role=button],input[type=button],input[type=submit]';
  let best=null, bestScore=0;
  for(const el of document.querySelectorAll(sel)){
    if(!vis(el)) continue;
    const label = norm(el.innerText || el.value || el.getAttribute('aria-label') || el.getAttribute('title'));
    if(!label || label.length>40) continue;
    const ctx = ctxText(el);
    let score=0, kind='';
    if(ACCEPT.includes(label)){ score = 100 + (cookieCtx(ctx)?20:0); kind='accept'; }
    else if(ACCEPT_WEAK.includes(label) && cookieCtx(ctx)){ score = 70; kind='accept'; }
    else if(CLOSE.includes(label) && inOverlay(el)){ score = 50; kind='close'; }
    if(score>bestScore){ bestScore=score; best={el,label,kind}; }
  }
  if(!best) return '';
  document.querySelectorAll('[data-hb-dismiss]').forEach(e=>e.removeAttribute('data-hb-dismiss'));
  best.el.setAttribute('data-hb-dismiss','1');
  return best.kind + '::' + best.label;   // plain string; eval just wraps it in quotes
})()
JS
)"
    # eval returns a JSON-encoded string -> strip the surrounding quotes
    res="${res%\"}"; res="${res#\"}"
    if [ -z "$res" ] || [ "$res" = "null" ]; then
      [ "$i" -eq 1 ] && echo "no overlay to dismiss"
      break
    fi
    kind="${res%%::*}"; label="${res#*::}"
    napms 250 650
    ab click '[data-hb-dismiss="1"]' >/dev/null 2>&1 || true
    echo "dismissed [$kind]: $label"
    acted=$((acted+1))
    napms 600 1200
  done
  [ "$acted" -gt 0 ] && echo "cleared $acted overlay(s)"
  return 0
}

# goto [--see] <url> — navigate the way a human arrives: open, let it settle,
# accept cookies / close pop-ups, THEN report whether you landed on real content
# or a risk-scored wall (runs `challenged`). Use this instead of bare `open` for
# any real site. Exit code mirrors `challenged` (0 ok / 1 blocked) so callers can
# branch: `hb goto URL && hb data list`. On a blocked verdict it captures a
# screenshot (saved HOST-side by agent-browser) and prints the host path so the
# user — who is on the Mac — can eyeball the wall. `--see` also emits an
# interactive snapshot so you get the @eN refs in the same step.
goto() {
  local see=0
  if [ "${1:-}" = "--see" ]; then see=1; shift; fi
  ab open "$1" >/dev/null 2>&1 || ab open "$1"
  think 1500 2800
  ab wait --load networkidle >/dev/null 2>&1 || true
  dismiss
  echo "→ $(ab get url 2>&1)"
  local rc=0
  challenged || rc=$?
  if [ "$rc" -ne 0 ]; then
    # No path arg: agent-browser saves to its own host temp dir and prints the
    # location. A container path would be wrong — agent-browser writes on the Mac.
    local shot
    shot="$(ab screenshot 2>&1 | sed -n 's/.*saved to //p')"
    [ -n "$shot" ] && echo "  ↳ screenshot (host): $shot"
  fi
  [ "$see" -eq 1 ] && ab snapshot -i
  return "$rc"
}

# waitfor url|vis <arg> [timeout_s] — poll, human-paced, until a condition holds.
#   url <regex>  : `ab get url` matches the extended regex
#   vis <sel>    : `ab is visible <sel>` reports the element is visible
# Prints the matched value and exits 0 on success; exits 1 on timeout. Iteration
# is bounded by a counter (each round ~1.5-2.8s of think), so it never tight-loops.
# NOTE: timeout_s is an approximate lower bound — the per-round `ab` SSH latency
# isn't counted, so real wall-clock runs somewhat longer than the nominal value.
waitfor() {
  # ${1:-}/${2:-}: under `set -u` a bare $1/$2 would abort with "unbound
  # variable" before the usage message below is ever reachable.
  local mode="${1:-}" arg="${2:-}" timeout="${3:-60}"
  if [ -z "$mode" ] || [ -z "$arg" ]; then
    echo "usage: hb waitfor url|vis <arg> [timeout_s]" >&2; return 2
  fi
  local rounds=$(( timeout * 10 / 21 + 1 ))   # ~2.1s avg/round -> ~timeout seconds
  local i=0 cur
  while [ "$i" -lt "$rounds" ]; do
    i=$((i+1))
    case "$mode" in
      url)
        cur="$(ab get url 2>/dev/null || true)"
        if printf '%s' "$cur" | grep -Eq -- "$arg"; then echo "$cur"; return 0; fi ;;
      vis)
        if ab is visible "$arg" >/dev/null 2>&1; then echo "visible: $arg"; return 0; fi ;;
      *) echo "usage: hb waitfor url|vis <arg> [timeout_s]" >&2; return 2 ;;
    esac
    think 1500 2800
  done
  echo "waitfor: timeout after ${timeout}s ($mode $arg)" >&2
  return 1
}

# mail new | code [timeout_s] — temp-email helper for mail.tm (CORS API, clean
# addresses). `new` opens the inbox and prints the anonymous address it created;
# `code` polls that inbox via an in-page fetch (the host SSH gateway denies
# arbitrary curl) and prints the first 4-8 digit OTP found in a message's
# subject/intro. Human-paced polling with a timeout — not a tight loop. (timeout_s
# is an approximate lower bound; per-round fetch/SSH latency isn't counted.)
mail() {
  case "${1:-}" in
    new)
      ab open https://mail.tm/en/ >/dev/null 2>&1 || ab open https://mail.tm/en/
      think 1800 3000
      ab wait --load networkidle >/dev/null 2>&1 || true
      dismiss >/dev/null 2>&1 || true
      # mail.tm auto-creates the account and stores it in localStorage.account.
      local addr
      addr="$(printf '%s' '(()=>{try{return JSON.parse(localStorage.getItem("account")).address}catch(e){return ""}})()' | ab eval --stdin 2>/dev/null || true)"
      addr="${addr%\"}"; addr="${addr#\"}"
      if [ -z "$addr" ] || [ "$addr" = "null" ]; then
        echo "mail: could not read address from mail.tm (is the tab loaded?)" >&2; return 1
      fi
      echo "$addr" ;;
    code)
      local timeout="${2:-120}" rounds i=0 out
      rounds=$(( timeout / 3 + 1 ))
      while [ "$i" -lt "$rounds" ]; do
        i=$((i+1))
        out="$(cat <<'JS' | ab eval --stdin 2>/dev/null || true
(async () => {
  let tok; try { tok = JSON.parse(localStorage.getItem('account')).token; } catch(e){ return 'NOAUTH'; }
  const r = await fetch('https://api.mail.tm/messages', {headers:{Authorization:'Bearer '+tok}});
  if (r.status === 401) return 'AUTHFAIL';   // expired/revoked JWT — polling on can't help
  const j = await r.json();
  const items = (j['hydra:member']||[]);   // mail.tm returns newest first
  const KW = /(code|verif|otp|pin|confirm|security|one[- ]?time|passcode|access)/i;
  // Pick the most code-like 4-8 digit run: prefer proximity to a code keyword
  // and longer runs; reject bare years (19xx/20xx) so a "© 2026" footer or a
  // date never wins over a real OTP.
  const pickCode = hay => {
    const re = /\b\d{4,8}\b/g; let m, best=null, bestScore=0;
    while ((m = re.exec(hay))) {
      const d = m[0];
      let s = d.length;
      const around = hay.slice(Math.max(0, m.index - 30), m.index + d.length + 30);
      if (KW.test(around)) s += 100;
      if (/^(19|20)\d{2}$/.test(d)) s -= 50;   // looks like a year -> below the s=0 floor
      if (s > bestScore) { bestScore = s; best = d; }
    }
    return best;
  };
  for (const m of items.slice(0, 5)) {
    const c = pickCode((m.subject||'') + ' \n ' + (m.intro||''));
    if (c) return c;
  }
  return 'EMPTY';
})()
JS
)"
        out="${out%\"}"; out="${out#\"}"
        case "$out" in
          NOAUTH) echo "mail code: no mail.tm auth token on this tab (run 'hb mail new' first, same tab)" >&2; return 1 ;;
          AUTHFAIL) echo "mail code: mail.tm rejected the auth token (401 — expired/revoked JWT); re-run 'hb mail new'" >&2; return 1 ;;
          EMPTY|"") : ;;
          *)
            # Only a plausible OTP leaves this function: 4-8 digits, nothing
            # else. An eval hiccup ('null'/'undefined', an error string, a
            # truncated payload) must never be printed as a code — treat it
            # as "no OTP yet" and keep polling.
            if printf '%s' "$out" | grep -Eq '^[0-9]{4,8}$'; then
              echo "$out"; return 0
            fi ;;
        esac
        think 2500 3800
      done
      echo "mail code: timeout after ${timeout}s (no OTP received)" >&2; return 1 ;;
    *) echo "usage: hb mail new|code [timeout_s]" >&2; return 2 ;;
  esac
}

# challenged — precise verdict for risk-scored walls (DataDome/PerimeterX/etc.).
# CRITICAL: the anti-bot SCRIPT being present in the HTML is NOT a block — that
# only means scoring is active. A block is a *visible* captcha-delivery iframe /
# interstitial with no real page content. Prints "ok: …" (exit 0) or
# "blocked: …" (exit 1) so you can branch: `hb challenged && extract...`.
challenged() {
  local res
  res="$(ab eval --stdin <<'JS'
(() => {
  const u = location.href;
  const vis = el => { if(!el) return false; const r=el.getBoundingClientRect(); return r.width>2&&r.height>2; };
  const ddIframe = document.querySelector('iframe[src*="captcha-delivery"],iframe[src*="geo.captcha-delivery"]');
  const body = (document.body.innerText||'');
  const interstitial = /verifying you are human|are you a human|please verify you are a human|enable javascript and cookies to continue|geo\.captcha/i.test(body.toLowerCase());
  const hasContent = !!document.querySelector('h1') && body.length > 800;
  if (/\/(captcha|interstitial|blocked)(\/|\?|$)/i.test(u)) return 'blocked::redirected to ' + u;
  if (vis(ddIframe)) return 'blocked::visible captcha-delivery iframe';
  if (interstitial && !hasContent) return 'blocked::interstitial text, no content';
  return 'ok::content ' + (hasContent ? 'present' : 'thin (re-check after load)');
})()
JS
)"
  res="${res%\"}"; res="${res#\"}"
  echo "${res/::/: }"
  case "$res" in blocked*) return 1;; *) return 0;; esac
}

# data [list|next|nuxt|apollo|ld|initial] — dump a page's EMBEDDED STATE instead
# of scraping the DOM. Modern SPAs render lazy/virtualized lists (often only ~2
# rows in the DOM at once — scraping them silently undercounts), but ship the
# FULL dataset in a JSON blob: Next.js `__NEXT_DATA__`, Nuxt `window.__NUXT__`,
# Apollo `__APOLLO_STATE__`, JSON-LD, or `__INITIAL_STATE__`. These also carry
# fields the DOM never shows. Returns clean JSON (eval re-serializes the object;
# returning an OBJECT — not a stringified one — avoids double-encoding).
#   hb data list                 # which blobs exist + sizes
#   hb data next > /tmp/nd.json  # dump __NEXT_DATA__, then filter with jq
data() {
  case "${1:-list}" in
    list)
      ab eval --stdin <<'JS'
(() => { const r={};
  const nd=document.getElementById('__NEXT_DATA__'); if(nd) r.next=nd.textContent.length;
  if(window.__NUXT__) r.nuxt=true;
  if(window.__APOLLO_STATE__) r.apollo=true;
  if(window.__INITIAL_STATE__) r.initial=true;
  const ld=document.querySelectorAll('script[type="application/ld+json"]'); if(ld.length) r.ld=ld.length;
  return r; })()
JS
      ;;
    next)    printf '(()=>{const n=document.getElementById("__NEXT_DATA__");return n?JSON.parse(n.textContent):null})()' | ab eval --stdin ;;
    nuxt)    printf 'window.__NUXT__ || null'         | ab eval --stdin ;;
    apollo)  printf 'window.__APOLLO_STATE__ || null' | ab eval --stdin ;;
    initial) printf 'window.__INITIAL_STATE__ || null'| ab eval --stdin ;;
    ld)      printf '[...document.querySelectorAll(%s)].map(s=>{try{return JSON.parse(s.textContent)}catch(e){return null}}).filter(Boolean)' "'script[type=\"application/ld+json\"]'" | ab eval --stdin ;;
    *) echo "usage: hb data [list|next|nuxt|apollo|ld|initial]" >&2; return 2 ;;
  esac
}

case "${1:-}" in
  think)     shift; think "$@" ;;
  humantype) shift; humantype "$@" ;;
  humanclick)shift; humanclick "$@" ;;
  fillform)  shift; fillform "$@" ;;
  dismiss)   shift; dismiss "$@" ;;
  challenged)shift; challenged "$@" ;;
  data)      shift; data "$@" ;;
  goto)      shift; goto "$@" ;;
  waitfor)   shift; waitfor "$@" ;;
  mail)      shift; mail "$@" ;;
  "")        ab ;;                 # no args -> ab help
  *)         ab "$@" ;;            # pass-through
esac
