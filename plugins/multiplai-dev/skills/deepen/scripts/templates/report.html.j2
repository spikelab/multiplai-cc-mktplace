<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Architecture review — {{ repo }}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script type="module">
      import mermaid from "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs";
      mermaid.initialize({ startOnLoad: true, theme: "neutral", securityLevel: "loose" });
    </script>
    <style>
      .seam { stroke-dasharray: 4 4; }
      .leak { stroke: #dc2626; }
      .deep { background: linear-gradient(135deg, #0f172a, #1e293b); }
      .badge { display: inline-block; padding: 0.125rem 0.5rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.025em; text-transform: uppercase; }
    </style>
  </head>
  <body class="bg-stone-50 text-slate-900 font-sans">
    <main class="max-w-5xl mx-auto px-6 py-12 space-y-12">
      <header class="space-y-3">
        <h1 class="text-3xl font-serif tracking-tight">Architecture review</h1>
        <div class="text-sm text-slate-500 space-x-4">
          <span class="font-mono">{{ repo }}</span>
          <span>{{ generated_at }}</span>
          <span>{{ candidates|length }} candidate{{ '' if candidates|length == 1 else 's' }}</span>
        </div>
        <div class="text-xs text-slate-500 flex flex-wrap gap-x-4 gap-y-1 pt-2 border-t border-slate-200">
          <span><span class="inline-block w-3 h-3 border border-slate-400 align-middle mr-1"></span>module</span>
          <span><span class="inline-block w-3 h-0.5 bg-slate-400 align-middle mr-1 seam"></span>seam</span>
          <span><span class="inline-block w-3 h-0.5 bg-red-600 align-middle mr-1"></span>leakage</span>
          <span><span class="inline-block w-3 h-3 deep align-middle mr-1"></span>deep module</span>
        </div>
      </header>

      <section id="candidates" class="space-y-10">
        {% for c in candidates %}
        <article id="candidate-{{ loop.index0 }}" class="rounded-xl border border-slate-200 bg-white shadow-sm p-6 space-y-4">
          <div class="flex flex-wrap items-baseline justify-between gap-2">
            <h2 class="text-xl font-serif">{{ c.title }}</h2>
            <div class="flex gap-2">
              <span class="badge {{ strength_class(c.strength) }}">{{ c.strength }}</span>
              <span class="badge bg-slate-100 text-slate-700">{{ c.dependency_category }}</span>
            </div>
          </div>

          {% if c.files %}
          <div class="font-mono text-sm text-slate-700 space-y-0.5">
            {% for f in c.files %}<div>{{ f }}</div>{% endfor %}
          </div>
          {% endif %}

          {% if c.diagram and c.diagram.kind == 'mermaid' %}
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="rounded-lg border border-slate-200 bg-white p-4">
              <div class="text-xs uppercase tracking-wider text-slate-500 mb-2">Before</div>
              <pre class="mermaid">{{ c.diagram.before }}</pre>
            </div>
            <div class="rounded-lg border-2 border-slate-900 bg-white p-4">
              <div class="text-xs uppercase tracking-wider text-slate-500 mb-2">After</div>
              <pre class="mermaid">{{ c.diagram.after }}</pre>
            </div>
          </div>
          {% endif %}

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
            <div>
              <div class="text-xs uppercase tracking-wider text-slate-500 mb-1">Problem</div>
              <p>{{ c.problem }}</p>
            </div>
            <div>
              <div class="text-xs uppercase tracking-wider text-slate-500 mb-1">Solution</div>
              <p>{{ c.solution }}</p>
            </div>
          </div>

          {% if c.wins %}
          <div>
            <div class="text-xs uppercase tracking-wider text-slate-500 mb-1">Wins</div>
            <ul class="list-disc list-inside text-sm space-y-0.5">
              {% for w in c.wins %}<li>{{ w }}</li>{% endfor %}
            </ul>
          </div>
          {% endif %}

          {% if c.adr_callout %}
          <div class="rounded border border-amber-300 bg-amber-50 px-4 py-2 text-sm text-amber-900">
            {{ c.adr_callout }}
          </div>
          {% endif %}
        </article>
        {% endfor %}
      </section>

      {% if top_recommendation %}
      <section id="top-recommendation" class="rounded-xl border-2 border-emerald-700 bg-emerald-50 p-6 space-y-2">
        <div class="text-xs uppercase tracking-wider text-emerald-800">Top recommendation</div>
        <h2 class="text-2xl font-serif">
          <a class="underline decoration-emerald-700 underline-offset-4" href="#candidate-{{ top_recommendation.index }}">
            {{ candidates[top_recommendation.index].title }}
          </a>
        </h2>
        <p class="text-sm text-emerald-900">{{ top_recommendation.why }}</p>
      </section>
      {% endif %}
    </main>
  </body>
</html>
